{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
#
# Apply chflags uchg to paths declared in .chezmoidata/protected_paths.toml.
# Each entry is a table with `path` and optional `recursive`.
#   recursive = false (default): chflags uchg <path>
#   recursive = true:             chflags -R uchg <path>
#
# Paths may use ~ for $HOME.
#
# This script only ADDS the flag. To unprotect a path:
#   1. remove the entry from .chezmoidata/protected_paths.toml
#   2. run `chflags nouchg <path>` (add -R for recursive entries) by hand
#
# Runs on every `chezmoi apply` (run_ without once_/onchange_) so that
# paths which didn't exist yet at the time of an earlier apply get picked
# up the next time you apply after creating them. chflags uchg is a no-op
# on files that are already uchg, so the cost is negligible.

set -Eeuo pipefail

if [ "${DOTFILES_DEBUG:-}" ]; then
  set -x
fi

{{ range .protected_paths -}}
raw="{{ .path }}"
path="${raw/#\~/$HOME}"
if [ ! -e "$path" ]; then
  echo "protect-files: skip (missing): $path" >&2
else
{{- if index . "recursive" }}
  chflags -R uchg "$path"
  echo "protect-files: locked (recursive): $path"
{{- else }}
  chflags uchg "$path"
  echo "protect-files: locked: $path"
{{- end }}
fi

{{ end -}}
{{- end }}
